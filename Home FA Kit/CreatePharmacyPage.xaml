<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Home_FA_Kit.CreatePharmacyPage"
             xmlns:resources="clr-namespace:Home_FA_Kit.Resources.Strings">

    <ContentPage.Content>
        <StackLayout Padding="7">
            <Label Text="{x:Static resources:AppResources.Label_CreateNewPharmacy}" FontSize="18" />
            <Entry x:Name="pharmacyNameEntry" Placeholder="{x:Static resources:AppResources.Entry_PharmacyName}" />
            <Button Text="{x:Static resources:AppResources.Button_Save}" Clicked="OnSavePharmacyClicked" BackgroundColor="#000AFF" AnchorY="50" AutomationProperties.IsInAccessibleTree="True"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>