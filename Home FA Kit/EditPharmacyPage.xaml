<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Home_FA_Kit.EditPharmacyPage"
             xmlns:resources="clr-namespace:Home_FA_Kit.Resources.Strings">

    <ContentPage.Content>
        <StackLayout Padding="7">
            <Label Text="{x:Static resources:AppResources.Label_EditPharmacy}" FontSize="18" />
            <Entry x:Name="pharmacyNameEntry" />
            <Button Text="{x:Static resources:AppResources.Button_Save}" Clicked="OnSavePharmacyClicked" />
        </StackLayout>
    </ContentPage.Content>
</ContentPage>